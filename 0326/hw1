#include<iostream>
#include<string>

using namespace std;

bool check(string id) {
    if (id.length() != 10) {
        return false;
    }
    
    if (id[0] < 'A' || id[0] > 'Z') {
        return false;
    }
    
    if (id[1] != '1' && id[1] != '2') {
        return false;
    }
    
    for (int i = 2; i < 10; i++) {
        if (id[i] < '0' || id[i] > '9') {
            return false;
        }
    }
    return true;
}

int main() {
    string id;
    cout << "Please enter an ID numbers： ";
    cin >> id;
    if (check(id)) cout << "Correct" << endl ;
    else cout <<"Incorrect" << endl;

    return 0;
}
